{
  "name": "rubypad",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "icons": "node scripts/generate-icons.mjs",
    "docs": "node scripts/build-docs.mjs",
    "postinstall": "node -e \"const{cpSync,mkdirSync}=require('fs');try{mkdirSync('public/rubywasm',{recursive:true});cpSync('node_modules/@ruby/4.0-wasm-wasi/dist/ruby.wasm','public/rubywasm/ruby.wasm')}catch(e){console.warn('ruby.wasm copy skipped:',e.message)}\""
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/cdk": "~21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "~21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.0",
    "@codemirror/legacy-modes": "^6.4.2",
    "@ruby/4.0-wasm-wasi": "^2.8.1",
    "@fsegurai/codemirror-theme-material-dark": "^6.2.3",
    "@fsegurai/codemirror-theme-material-light": "^6.2.3",
    "codemirror": "^6.0.2",
    "lz-string": "^1.5.0",
    "marked": "^17.0.4",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/material": "^21.2.0",
    "@fontsource/material-icons": "^5.2.7",
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/roboto-mono": "^5.2.8",
    "@types/lz-string": "^1.3.34",
    "@types/qrcode": "^1.5.6",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
